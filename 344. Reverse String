class Solution {
    public void reverseString(char[] s) {
        int a=0;
        int q=s.length-1;
        while(a<q){
           char temp=s[a];// using swap condepts of arrays the question is done
           s[a]=s[q];
           s[q]=temp;
           a++;
           q--;
           
        }
    }
}
